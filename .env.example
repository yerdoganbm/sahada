# ─── Google Maps / Places ──────────────────────────────────────────────────────
# Saha Konumu, haritada aç, yakınımdaki sahalar için kullanılır.
# Google Cloud Console → APIs & Services → Credentials → API Key
# Etkinleştirmeniz gereken API'lar:
#   - Maps JavaScript API
#   - Places API
#   - Geocoding API (opsiyonel)
VITE_GOOGLE_MAPS_API_KEY=

# Map ID (opsiyonel – Google Maps Cloud Styling için)
VITE_GOOGLE_MAPS_MAP_ID=

# ─── Expo / React Native (mobil) ──────────────────────────────────────────────
# Expo SDK 49+ ile EXPO_PUBLIC_ prefix ile ortam değişkeni tanımlanır
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
