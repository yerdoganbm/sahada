# ─── Google Maps / Places ──────────────────────────────────────────────────────
# Saha Konumu, haritada aç, yakınımdaki sahalar için kullanılır.
# Google Cloud Console → APIs & Services → Credentials → API Key
# Etkinleştirmeniz gereken API'lar:
#   - Maps JavaScript API
#   - Places API
#   - Geocoding API (opsiyonel)
VITE_GOOGLE_MAPS_API_KEY=

# Map ID (opsiyonel – Google Maps Cloud Styling için)
VITE_GOOGLE_MAPS_MAP_ID=

# ─── Expo / React Native (mobil) ──────────────────────────────────────────────
# Expo SDK 49+ ile EXPO_PUBLIC_ prefix ile ortam değişkeni tanımlanır
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Firebase (MVP — Web + Android + iOS) ─────────────────────────────────────
# Firebase Console → Project Settings → General → Your apps → Web app config
# VITE_USE_FIREBASE=true    → Firebase (Firestore + Auth + Storage)
# VITE_USE_FIREBASE=false   → Mock/Demo (varsayılan, API key gerekmez)
VITE_USE_FIREBASE=false

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Expo / React Native
EXPO_PUBLIC_USE_FIREBASE=false
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Feature flags
VITE_FLAGS_PHONE_OTP=false
VITE_FLAGS_STORAGE_UPLOAD=false
